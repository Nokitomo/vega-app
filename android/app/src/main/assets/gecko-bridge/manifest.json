{
  "manifest_version": 2,
  "name": "Vega Gecko Bridge",
  "version": "1.0.0",
  "description": "Built-in bridge extension used by GeckoView on Android.",
  "browser_specific_settings": {
    "gecko": {
      "id": "gecko-bridge@vega.app"
    }
  },
  "permissions": [
    "geckoViewAddons",
    "nativeMessaging",
    "nativeMessagingFromContent"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  }
}
